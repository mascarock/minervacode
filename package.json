{
  "name": "minervacli",
  "version": "0.4.2",
  "description": "Terminal chat client and assisted coding companion for Chat Minerva",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "bin/",
    "dist/",
    "assets/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "bin": {
    "minervacli": "./bin/minervacli"
  },
  "scripts": {
    "prebuild": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "diff": "^9.0.0",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
